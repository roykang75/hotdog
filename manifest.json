{
  "manifest_version": 3,
  "name": "Hotdog Translator",
  "version": "1.0.0",
  "description": "웹 페이지의 텍스트를 선택한 언어로 번역합니다",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"]
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["youtube-main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
